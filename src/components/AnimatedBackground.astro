---
import { BACKGROUND } from '../consts';

// Render nothing at all when disabled — no canvas, no script, zero cost.
const { enabled, variant } = BACKGROUND;

interface Props {
  /**
   * Colour profile for the background. Same animation, different palette.
   * 'default' = site blue-green. 'books' = dark fantasy red / silvery-blue.
   * Pages opt in via BaseLayout's `backgroundTheme` prop.
   */
  theme?: 'default' | 'books';
}
const { theme = 'default' } = Astro.props;
---

{
  enabled && (
    <canvas
      id="bg-canvas"
      data-variant={variant}
      data-theme={theme}
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 h-full w-full"
    />
  )
}

{
  enabled && (
    <script is:inline>
      (() => {
        const canvas = document.getElementById('bg-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        // Variant + theme come from data-attributes, with optional ?bg= and
        // ?theme= overrides for previewing.
        const params = new URLSearchParams(location.search);
        const variant = params.get('bg') || canvas.dataset.variant || 'network';
        const themeName =
          params.get('theme') || canvas.dataset.theme || 'default';

        // Colour profiles. `base` drives structural marks (grid dots, network
        // lines); `pulses` is the palette the moving stars/streams draw from at
        // random; `wash` matches the page background so trails fade cleanly.
        // The wash stays navy/slate for every theme so the base never tints.
        const THEMES = {
          default: {
            base: [92, 192, 171],
            pulses: [[92, 192, 171]],
            wash: 'rgba(13, 19, 32, 0.20)',
          },
          books: {
            // Muted slate-blue for any structural marks (kept subtle).
            base: [110, 130, 160],
            // Deep red and silvery blue dominate; ember red is an occasional
            // brighter accent (weighted by repetition).
            pulses: [
              [143, 29, 29], // deep red    #8f1d1d
              [143, 29, 29],
              [143, 29, 29],
              [159, 184, 214], // silvery blue #9fb8d6
              [159, 184, 214],
              [159, 184, 214],
              [194, 65, 45], // ember red   #c2412d
            ],
            wash: 'rgba(13, 19, 32, 0.20)',
          },
        };
        const theme = THEMES[themeName] || THEMES.default;

        // Colour helpers. `base` is the single structural colour; `pulse`
        // picks a random colour from the theme palette for one element.
        const rgba = (c, a) =>
          'rgba(' + c[0] + ',' + c[1] + ',' + c[2] + ',' + a + ')';
        const base = (a) => rgba(theme.base, a);
        const pickPulse = () =>
          theme.pulses[(Math.random() * theme.pulses.length) | 0];
        const reduce = matchMedia('(prefers-reduced-motion: reduce)');

        let w = 0, h = 0, dpr = 1;
        let nodes = [], packets = [], cols = [], vcols = [], gridGap = 48, phase = 0;
        let raf = 0, last = 0;

        // Depth layers for 'vertical-streams' (far -> near). Nearer layers are
        // sparser, faster, brighter and larger for a parallax sense of depth.
        const V_LAYERS = [
          { gap: 17, speed: [16, 34], lw: 1, head: 6, alpha: 0.16, rise: 0.18 },
          { gap: 24, speed: [30, 60], lw: 1.6, head: 10, alpha: 0.34, rise: 0.14 },
          { gap: 36, speed: [52, 95], lw: 2.4, head: 15, alpha: 0.6, rise: 0.1 },
        ];
        const FPS = 30, interval = 1000 / FPS;

        function size() {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          w = window.innerWidth;
          h = window.innerHeight;
          canvas.width = Math.floor(w * dpr);
          canvas.height = Math.floor(h * dpr);
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        function spawnPacket() {
          const horizontal = Math.random() < 0.5;
          const speed = 30 + Math.random() * 45;
          const dir = Math.random() < 0.5 ? 1 : -1;
          const color = pickPulse();
          if (horizontal) {
            const row = Math.round((Math.random() * h) / gridGap) * gridGap;
            return { horizontal: true, x: Math.random() * w, y: row, dir, speed, color };
          }
          const col = Math.round((Math.random() * w) / gridGap) * gridGap;
          return { horizontal: false, x: col, y: Math.random() * h, dir, speed, color };
        }

        function init() {
          if (variant === 'network') {
            const count = Math.min(70, Math.floor((w * h) / 24000));
            nodes = Array.from({ length: count }, () => ({
              x: Math.random() * w,
              y: Math.random() * h,
              vx: (Math.random() - 0.5) * 0.25,
              vy: (Math.random() - 0.5) * 0.25,
              r: 1.2 + Math.random() * 1.4,
              p: Math.random() * Math.PI * 2,
              color: pickPulse(),
            }));
          } else if (variant === 'grid') {
            packets = Array.from({ length: 7 }, spawnPacket);
          } else if (variant === 'vertical-streams') {
            vcols = [];
            for (let li = 0; li < V_LAYERS.length; li++) {
              const L = V_LAYERS[li];
              const n = Math.floor(w / L.gap);
              for (let i = 0; i < n; i++) {
                const rising = Math.random() < L.rise;
                vcols.push({
                  layer: li,
                  x: i * L.gap + L.gap / 2 + (Math.random() - 0.5) * 4,
                  y: Math.random() * h,
                  dir: rising ? -1 : 1,
                  speed: L.speed[0] + Math.random() * (L.speed[1] - L.speed[0]),
                  // Per-column brightness jitter so pulses don't look uniform.
                  bright: 0.75 + Math.random() * 0.45,
                  // Colour drawn from the theme palette (red / silvery blue).
                  color: pickPulse(),
                });
              }
            }
          } else {
            // 'streams' — slightly busier than before (more active, a touch faster).
            const gap = 24;
            const n = Math.floor(w / gap);
            cols = Array.from({ length: n }, (_, i) => ({
              x: i * gap + gap / 2,
              y: Math.random() * h,
              speed: 26 + Math.random() * 44,
              len: 7 + Math.floor(Math.random() * 11),
              active: Math.random() < 0.72,
              color: pickPulse(),
            }));
          }
        }

        function drawNetwork(dt) {
          ctx.clearRect(0, 0, w, h);
          const k = dt * 60;
          for (const n of nodes) {
            n.x += n.vx * k; n.y += n.vy * k; n.p += dt * 1.2;
            if (n.x < 0 || n.x > w) n.vx *= -1;
            if (n.y < 0 || n.y > h) n.vy *= -1;
          }
          const D = 150;
          for (let i = 0; i < nodes.length; i++) {
            for (let j = i + 1; j < nodes.length; j++) {
              const dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y;
              const dist = Math.hypot(dx, dy);
              if (dist < D) {
                ctx.strokeStyle = base((1 - dist / D) * 0.16);
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(nodes[i].x, nodes[i].y);
                ctx.lineTo(nodes[j].x, nodes[j].y);
                ctx.stroke();
              }
            }
          }
          for (const n of nodes) {
            const rr = n.r + Math.sin(n.p) * 0.4;
            ctx.fillStyle = rgba(n.color, 0.45);
            ctx.beginPath();
            ctx.arc(n.x, n.y, rr, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        function drawGrid(dt) {
          ctx.clearRect(0, 0, w, h);
          phase += dt * 0.6;
          for (let y = gridGap; y < h; y += gridGap) {
            for (let x = gridGap; x < w; x += gridGap) {
              const a = 0.05 + 0.06 * Math.sin(phase + (x + y) * 0.01);
              if (a <= 0) continue;
              ctx.fillStyle = base(a);
              ctx.fillRect(x - 0.8, y - 0.8, 1.6, 1.6);
            }
          }
          for (const p of packets) {
            if (p.horizontal) p.x += p.dir * p.speed * dt;
            else p.y += p.dir * p.speed * dt;
            if (p.x < -40 || p.x > w + 40 || p.y < -40 || p.y > h + 40) {
              Object.assign(p, spawnPacket());
            }
            const tailX = p.horizontal ? p.x - p.dir * 26 : p.x;
            const tailY = p.horizontal ? p.y : p.y - p.dir * 26;
            const g = ctx.createLinearGradient(tailX, tailY, p.x, p.y);
            g.addColorStop(0, rgba(p.color, 0));
            g.addColorStop(1, rgba(p.color, 0.5));
            ctx.strokeStyle = g;
            ctx.lineWidth = 1.5;
            ctx.beginPath();
            ctx.moveTo(tailX, tailY);
            ctx.lineTo(p.x, p.y);
            ctx.stroke();
            ctx.fillStyle = rgba(p.color, 0.6);
            ctx.beginPath();
            ctx.arc(p.x, p.y, 1.6, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        function drawStreams(dt) {
          ctx.clearRect(0, 0, w, h);
          const lineH = 14;
          for (const c of cols) {
            if (!c.active) continue;
            c.y += c.speed * dt;
            if (c.y - c.len * lineH > h) {
              c.y = -Math.random() * h * 0.3;
              c.speed = 26 + Math.random() * 44;
              c.len = 7 + Math.floor(Math.random() * 11);
              c.active = Math.random() < 0.85;
              c.color = pickPulse();
            }
            for (let i = 0; i < c.len; i++) {
              const yy = c.y - i * lineH;
              if (yy < 0 || yy > h) continue;
              const a = (1 - i / c.len) * 0.28;
              ctx.fillStyle = rgba(c.color, i === 0 ? 0.6 : a);
              ctx.fillRect(c.x, yy, 2, 8);
            }
          }
        }

        function drawVerticalStreams(dt) {
          // Translucent base-coloured wash creates fading trails (data rain)
          // without a separate per-column trail loop — cheap and smooth.
          ctx.fillStyle = theme.wash;
          ctx.fillRect(0, 0, w, h);
          for (const c of vcols) {
            const L = V_LAYERS[c.layer];
            c.y += c.dir * c.speed * dt;
            // Recycle past the edge in the direction of travel.
            if (c.dir > 0 && c.y - L.head > h) {
              c.y = -Math.random() * h * 0.4;
              c.speed = L.speed[0] + Math.random() * (L.speed[1] - L.speed[0]);
              c.bright = 0.75 + Math.random() * 0.45;
              c.color = pickPulse();
            } else if (c.dir < 0 && c.y + L.head < 0) {
              c.y = h + Math.random() * h * 0.4;
              c.speed = L.speed[0] + Math.random() * (L.speed[1] - L.speed[0]);
              c.bright = 0.75 + Math.random() * 0.45;
              c.color = pickPulse();
            }
            // Bright leading pulse; the wash above turns its path into a trail.
            ctx.fillStyle = rgba(c.color, Math.min(L.alpha * c.bright + 0.12, 0.85));
            ctx.fillRect(c.x - L.lw / 2, c.y, L.lw, L.head);
          }
        }

        function frame(dt) {
          if (variant === 'grid') drawGrid(dt);
          else if (variant === 'streams') drawStreams(dt);
          else if (variant === 'vertical-streams') drawVerticalStreams(dt);
          else drawNetwork(dt);
        }

        function loop(t) {
          raf = requestAnimationFrame(loop);
          if (document.hidden) { last = t; return; }
          if (t - last < interval) return;
          const dt = Math.min((t - last) / 1000, 0.05);
          last = t;
          frame(dt);
        }

        function startLoop() {
          cancelAnimationFrame(raf);
          if (reduce.matches) {
            // Static, single representative frame — no motion.
            frame(0.016);
            return;
          }
          last = performance.now();
          raf = requestAnimationFrame(loop);
        }

        let resizeTimer = 0;
        function onResize() {
          clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(() => { size(); init(); startLoop(); }, 150);
        }

        size();
        init();
        startLoop();
        window.addEventListener('resize', onResize);
        // React if the user toggles their reduced-motion preference.
        reduce.addEventListener('change', startLoop);
      })();
    </script>
  )
}
