---
import { SITE, NAV, SOCIAL_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border/80">
  <div class="mx-auto max-w-5xl px-5 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <p class="font-semibold text-ink">{SITE.name}</p>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          A personal website, writing hub, and project archive — a home for my
          work, ideas, notes, and the things I'm learning.
        </p>
      </div>

      <nav aria-label="Footer" class="flex flex-col gap-6 sm:flex-row sm:gap-12">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">
            Site
          </h2>
          <ul class="mt-3 flex flex-col gap-2">
            {
              NAV.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-sm text-muted hover:text-ink transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">
            Elsewhere
          </h2>
          <ul class="mt-3 flex flex-col gap-2">
            {
              SOCIAL_LINKS.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted hover:text-ink transition-colors"
                    {...link.href.startsWith('http')
                      ? { target: '_blank', rel: 'me noopener noreferrer' }
                      : {}}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </div>

    <p class="mt-10 text-xs text-muted">
      &copy; {year} {SITE.name}. Built with Astro.
    </p>
  </div>
</footer>
