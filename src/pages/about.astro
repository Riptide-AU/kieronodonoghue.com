---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import vulcan from '../assets/images/vulcan.png';
import sailing from '../assets/images/sailing.png';

// Small structured data keeps the template readable and easy to edit later.
const atAGlance = [
  { label: 'Role', value: 'Corporate Services Analyst' },
  { label: 'Field', value: 'Construction industry' },
  { label: 'Based in', value: 'Australia' },
  { label: 'Studying', value: 'B.Commerce (Accounting)' },
];

const currentFocus = [
  {
    title: 'Business systems & process improvement',
    body: 'Making the systems behind day-to-day operations more reliable and less manual.',
  },
  {
    title: 'Analytics & reporting',
    body: 'Turning operational and financial data into reporting people can actually use.',
  },
  {
    title: 'Building & learning',
    body: 'Developing practical coding skills through real projects, including this site.',
  },
];

const education = [
  {
    qualification: 'Business Analytics',
    detail: 'Graduate. The foundation for how I read and work with data.',
  },
  {
    qualification: 'Bachelor of Commerce (Accounting)',
    detail: 'In progress. The systems and rules behind the numbers.',
  },
];

const learning = [
  { name: 'Python', note: 'Automation and analysis' },
  { name: 'SQL', note: 'Querying and shaping data' },
  { name: 'JavaScript', note: 'Web application work' },
  { name: 'CSS', note: 'Layout and interface' },
];

const interests = [
  'Business analytics',
  'Process improvement',
  'Automation',
  'Accounting & commercial systems',
  'The construction industry',
  'AI',
  'Web development',
  'Game design',
  'Boats, motorcycles & practical DIY',
];

// "Beyond work" — personal interests. Authentic and light on detail by design.
const beyond = [
  {
    title: 'Motorcycles',
    image: vulcan,
    alt: 'Stylised artwork of a motorcycle',
    body: 'I enjoy riding and tinkering with motorcycles — practical, mechanical, and a good reason to work with my hands.',
  },
  {
    title: 'Sailing & boats',
    image: sailing,
    alt: 'Stylised artwork of a sailing boat on the water',
    body: 'Time on the water is my reset. Boats are another kind of system to understand, maintain, and get right.',
  },
  {
    title: 'Technology & projects',
    image: null,
    alt: '',
    body: 'Building things for the fun of it — code, automation, and side projects that double as a way to keep learning.',
  },
];

const timeline = [
  {
    title: 'Studied business analytics',
    body: 'Learned to work with data as a way of understanding how organisations actually operate.',
  },
  {
    title: 'Moved into corporate services',
    body: 'Started applying analytics, accounting, and systems thinking to real operational work in the construction industry.',
  },
  {
    title: 'Studying accounting',
    body: 'Began a Bachelor of Commerce in Accounting to deepen the commercial side of that work.',
  },
  {
    title: 'Building and writing in public',
    body: 'Started developing my coding skills through practical projects and writing about what I learn — including this site.',
  },
];
---

<BaseLayout
  title="About"
  description="About Kieron O'Donoghue — a Corporate Services Analyst, Business Analytics graduate, and Bachelor of Commerce (Accounting) student based in Australia."
>
  <!-- INTRO / HERO -->
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-10 md:pt-24">
    <p class="text-xs font-semibold uppercase tracking-wider text-accent">About</p>
    <div class="mt-3 grid gap-10 md:grid-cols-[1.6fr_1fr] md:items-start">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-ink md:text-4xl">
          I'm Kieron O'Donoghue.
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-muted">
          I work at the intersection of business, technology, analytics, and
          accounting. I like understanding how things actually work — then making
          them work better. This site is where I keep that work, write about what
          I'm learning, and think out loud about ideas.
        </p>
      </div>

      <!-- At-a-glance panel -->
      <dl class="rounded-2xl border border-border bg-surface p-6">
        {
          atAGlance.map((item) => (
            <div class="flex justify-between gap-4 border-b border-border/70 py-3 first:pt-0 last:border-0 last:pb-0">
              <dt class="text-sm text-muted">{item.label}</dt>
              <dd class="text-sm font-medium text-ink text-right">
                {item.value}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- WHO I AM -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <div class="grid gap-8 md:grid-cols-[220px_1fr] md:items-baseline">
      <h2 class="text-2xl font-semibold tracking-tight text-ink">Who I am</h2>
      <div class="space-y-4 text-lg leading-relaxed text-ink/90">
        <p>
          I'm a practical, curious, analytical person. I'm more interested in
          building systems that work than in talking about them, and I'd rather
          be honest about what I'm still learning than overstate what I know.
        </p>
        <p>
          Most of what I do comes back to the same instinct: take something messy
          or repetitive, understand it properly, and make it simpler and more
          reliable.
        </p>
      </div>
    </div>
  </section>

  <!-- CURRENT FOCUS -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <h2 class="text-2xl font-semibold tracking-tight text-ink">Current focus</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      {
        currentFocus.map((item) => (
          <div class="rounded-xl border border-border bg-surface p-5">
            <h3 class="font-semibold text-ink">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <h2 class="text-2xl font-semibold tracking-tight text-ink">Education</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        education.map((item) => (
          <div class="rounded-xl border border-border bg-surface p-5">
            <h3 class="font-semibold text-ink">{item.qualification}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- AREAS I'M LEARNING -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <h2 class="text-2xl font-semibold tracking-tight text-ink">
      Areas I'm learning
    </h2>
    <p class="mt-3 max-w-2xl text-muted">
      I'm developing these through practical work and personal projects — learning
      as I build, not claiming to be an expert.
    </p>
    <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {
        learning.map((item) => (
          <div class="rounded-xl border border-border bg-surface-2/40 p-4">
            <p class="font-mono text-sm font-semibold text-accent">{item.name}</p>
            <p class="mt-1 text-sm text-muted">{item.note}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- INTERESTS -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <h2 class="text-2xl font-semibold tracking-tight text-ink">Interests</h2>
    <ul class="mt-6 flex flex-wrap gap-2">
      {
        interests.map((interest) => (
          <li class="rounded-full border border-border bg-surface px-3 py-1.5 text-sm text-ink/90">
            {interest}
          </li>
        ))
      }
    </ul>
  </section>

  <!-- BEYOND WORK -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <h2 class="text-2xl font-semibold tracking-tight text-ink">Beyond work</h2>
    <p class="mt-3 max-w-2xl text-muted">
      There's more to me than the professional side. A few of the things I spend
      time on away from the desk.
    </p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        beyond.map((item) => (
          <article class="flex flex-col overflow-hidden rounded-xl border border-border bg-surface">
            {item.image ? (
              <div class="aspect-[3/2] overflow-hidden border-b border-border">
                <Image
                  src={item.image}
                  alt={item.alt}
                  widths={[320, 640, 960]}
                  sizes="(min-width: 1024px) 20rem, (min-width: 640px) 50vw, 100vw"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover"
                />
              </div>
            ) : (
              <div
                class="flex aspect-[3/2] items-center justify-center border-b border-border bg-accent-soft/40"
                aria-hidden="true"
              >
                <span class="font-mono text-sm text-accent">&lt;/&gt;</span>
              </div>
            )}
            <div class="flex flex-1 flex-col p-5">
              <h3 class="font-semibold text-ink">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{item.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- PERSONAL PHILOSOPHY (callout) -->
  <section class="mx-auto max-w-5xl px-5 py-10">
    <blockquote
      class="rounded-2xl border border-accent/30 bg-accent-soft/40 p-8 md:p-10"
    >
      <p class="text-xl font-medium leading-relaxed text-ink md:text-2xl">
        “Understand the process before you try to improve it. Automating a messy
        routine just produces a faster mess.”
      </p>
      <footer class="mt-4 text-sm text-muted">
        A principle that shapes most of how I work.
      </footer>
    </blockquote>
  </section>

  <!-- JOURNEY / TIMELINE -->
  <section class="mx-auto max-w-5xl px-5 py-10 pb-16">
    <h2 class="text-2xl font-semibold tracking-tight text-ink">Journey</h2>
    <ol class="mt-8 border-l border-border">
      {
        timeline.map((item) => (
          <li class="relative pl-8 pb-8 last:pb-0">
            <span
              class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-base"
              aria-hidden="true"
            />
            <h3 class="font-semibold text-ink">{item.title}</h3>
            <p class="mt-1 text-muted">{item.body}</p>
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>
