---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCover from '../../components/BookCover.astro';
import PlaceholderCover from '../../components/PlaceholderCover.astro';
import { SITE } from '../../consts';

export const getStaticPaths = (async () => {
  const books = await getCollection('books', (b) => !b.data.draft);
  return books.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const data = entry.data;

// Published books get the full interactive hero; everything else (In
// Development, In Planning, …) renders as a forthcoming placeholder.
const isPublished = data.status === 'Published';

const ordinal =
  ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven'][
    data.bookNumber ?? 0
  ] ?? `${data.bookNumber}`;

const seriesLine = data.series
  ? `${data.series}${data.bookNumber ? ` — Book ${ordinal}` : ''}`
  : undefined;

// "Book Two of the Soul War Saga" line printed on the placeholder cover.
const seriesText =
  data.series && data.bookNumber
    ? `Book ${ordinal} of the ${data.series}`
    : data.series;

// Blurb (published only) — a single multi-paragraph string in frontmatter.
const blurbParagraphs = data.blurb
  ? data.blurb.split('\n\n').map((p) => p.trim()).filter(Boolean)
  : [];

// Optional sample excerpt, split into paragraphs on blank lines. Rendered as
// plain text (not Markdown) so the punctuation and dialogue stay verbatim.
const excerptParagraphs = data.excerpt
  ? data.excerpt.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean)
  : [];

const metaDescription =
  data.description ?? blurbParagraphs[0] ?? data.teaser ?? SITE.description;

// Absolute URLs for canonical + structured data.
const canonical = new URL(`/books/${entry.id}/`, SITE.url).href;
const coverUrl = data.coverImage
  ? new URL(data.coverImage.src, SITE.url).href
  : undefined;

// schema.org Book — associates Kieron O'Donoghue, the title, the series and
// genre. `creativeWorkStatus` records the lifecycle stage; forthcoming books
// deliberately omit offers/bookFormat/datePublished so they are never
// presented as published or purchasable.
const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: data.title,
  url: canonical,
  description: metaDescription,
  inLanguage: SITE.lang,
  creativeWorkStatus: data.status,
  genre: data.genre,
  author: {
    '@type': 'Person',
    name: data.author,
    url: SITE.url,
  },
  ...(coverUrl && { image: coverUrl }),
  ...(isPublished && { bookFormat: 'https://schema.org/EBook' }),
  ...(data.series && {
    isPartOf: {
      '@type': 'BookSeries',
      name: data.series,
      ...(data.bookNumber && { position: data.bookNumber }),
    },
  }),
  ...(data.publishedDate && {
    datePublished: data.publishedDate.toISOString().slice(0, 10),
  }),
  ...(data.buyLink && {
    offers: {
      '@type': 'Offer',
      url: data.buyLink,
      availability: 'https://schema.org/InStock',
    },
  }),
};
---

<BaseLayout
  title={data.title}
  description={metaDescription}
  type="article"
  image={coverUrl}
  publishedDate={data.publishedDate}
  backgroundTheme="books"
>
  <!-- HERO -->
  <section class="mx-auto max-w-5xl px-5 pt-12 pb-8 md:pt-16">
    <a href="/books/" class="text-sm text-muted transition-colors hover:text-accent">
      ← Books
    </a>

    <div class="mt-8 text-center">
      {
        seriesLine && (
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
            {seriesLine}
          </p>
        )
      }
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink md:text-5xl">
        {data.title}
      </h1>
      <p class="mt-3 text-base text-muted">
        by <span class="text-ink">{data.author}</span>
      </p>

      {
        isPublished ? (
          <>
            {data.genre.length > 0 && (
              <div class="mt-5 flex flex-wrap justify-center gap-2">
                {data.genre.map((g) => (
                  <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-ink/90">
                    {g}
                  </span>
                ))}
              </div>
            )}
            {data.buyLink && (
              <div class="mt-7">
                <a
                  href={data.buyLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-[#06231f] transition-colors hover:bg-accent-strong"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <path d="M3 6h18" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                  </svg>
                  Buy on Amazon
                </a>
              </div>
            )}
          </>
        ) : (
          <div class="mt-5 flex justify-center">
            <span class="inline-flex items-center gap-2 rounded-full border border-accent/40 bg-accent-soft px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true" />
              {data.status}
            </span>
          </div>
        )
      }
    </div>

    {
      isPublished && data.coverImage ? (
        /* Published: the interactive book that opens to reveal the blurb. */
        <div class="mt-12 flex justify-center pb-4">
          <BookCover
            src={data.coverImage}
            alt={data.coverImageAlt ?? data.title}
            title={data.title}
            author={data.author}
            seriesName={data.series}
            bookLabel={data.bookNumber ? `Book ${ordinal}` : undefined}
            paragraphs={blurbParagraphs}
          />
        </div>
      ) : (
        /* Forthcoming: a static cover as the main visual — the real artwork
           when it exists, otherwise a CSS placeholder — plus status/teaser. */
        <div class="mt-12 flex flex-col items-center pb-4">
          <div class="w-52 sm:w-60">
            {data.coverImage ? (
              <div class="overflow-hidden rounded-md border border-border shadow-lg shadow-black/40">
                <Image
                  src={data.coverImage}
                  alt={data.coverImageAlt ?? data.title}
                  widths={[240, 384, 480, 640]}
                  sizes="(min-width: 640px) 15rem, 13rem"
                  loading="eager"
                  decoding="async"
                  class="block h-auto w-full"
                />
              </div>
            ) : (
              <PlaceholderCover
                title={data.title}
                seriesText={seriesText}
                variant={data.placeholderCover ?? 'steel'}
              />
            )}
          </div>
          {data.teaser && (
            <p class="mt-9 max-w-xl text-center text-lg italic leading-relaxed text-ink/90">
              {data.teaser}
            </p>
          )}
          {data.note && (
            <p class="mt-4 max-w-xl text-center text-sm leading-relaxed text-muted">
              {data.note}
            </p>
          )}
        </div>
      )
    }
  </section>

  {/* EXCERPT + BANNER — published books only */}
  {
    isPublished && (
      <section class="mx-auto max-w-3xl px-5 py-6">
        <div class="rounded-2xl border border-border bg-surface p-6 md:p-8">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-accent">
            Excerpt
          </h2>
          {excerptParagraphs.length > 0 ? (
            <div class="prose mt-4 max-w-none">
              {excerptParagraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          ) : (
            <p class="mt-3 text-sm leading-relaxed text-muted">
              A sample chapter from {data.title} will be published here soon. In
              the meantime, you can read the opening on Amazon.
            </p>
          )}
        </div>
      </section>
    )
  }

  {
    isPublished && data.bannerImage && (
      <section class="mx-auto max-w-5xl px-5 py-14">
        <div class="overflow-hidden rounded-2xl border border-border bg-surface shadow-xl shadow-black/40 ring-1 ring-accent/10">
          <Image
            src={data.bannerImage}
            alt={data.bannerImageAlt ?? `${data.title} — promotional banner`}
            widths={[640, 960, 1280, 1600, 1920]}
            sizes="(min-width: 1024px) 61rem, 100vw"
            loading="lazy"
            decoding="async"
            class="block h-auto w-full"
          />
        </div>
      </section>
    )
  }

  <!-- MORE FROM KIERON -->
  <section class="mx-auto max-w-3xl px-5 py-10">
    <hr class="mb-10 border-border" />
    <h2 class="text-xl font-semibold tracking-tight text-ink">
      More from Kieron
    </h2>
    <p class="mt-2 text-sm text-muted">
      I also write about technology, analytics, and the things I'm building.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a
        href="/writing/"
        class="rounded-md border border-border px-4 py-2 text-sm font-medium text-ink transition-colors hover:border-accent/60 hover:text-accent"
      >
        Writing →
      </a>
      <a
        href="/ideas/"
        class="rounded-md border border-border px-4 py-2 text-sm font-medium text-ink transition-colors hover:border-accent/60 hover:text-accent"
      >
        Ideas →
      </a>
    </div>
  </section>

  <!-- Book structured data -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(bookSchema)}
  />
</BaseLayout>
